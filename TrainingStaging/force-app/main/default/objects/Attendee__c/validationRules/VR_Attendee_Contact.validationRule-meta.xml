<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_Attendee_Contact</fullName>
    <active>true</active>
    <description>At least one field (Email or Phone) must be filled.</description>
    <errorConditionFormula>AND( ISBLANK(Email__c), ISBLANK(Phone__c) )</errorConditionFormula>
    <errorMessage>Enter Email or Phone.</errorMessage>
</ValidationRule>
